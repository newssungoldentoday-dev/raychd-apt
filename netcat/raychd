#!/usr/bin/env bash
#
# raychd — netcat-based IRC client for Ray Chad
# Requires: nc (netcat)
#
# Usage:
#   ./raychd <server> <port> <nickname> [#channel]
#
# Example:
#   ./raychd irc.raychad.local 6667 blue #general
#
# In-session commands:
#   /join #channel               join a channel
#   /part #channel [msg]         leave a channel
#   /msg <target> <text>         send a message to a channel or user
#   /me <text>                   send an action to the current channel
#   /nick <newnick>              change your nickname
#   /topic #channel [text]       view or set a channel topic
#   /kick #channel <nick> [msg]  kick a user from a channel
#   /mode <target> <flags>       set user or channel modes
#   /whois <nick>                look up info on a user
#   /whowas <nick>               look up info on a disconnected user
#   /invite <nick> #channel      invite a user to a channel
#   /notice <target> <text>      send a notice
#   /away [msg]                  mark yourself away (no arg clears it)
#   /list                        list channels on the server
#   /names #channel              list users in a channel
#   /ctcp <target> <cmd>         send a CTCP request (e.g. VERSION)
#   /raw <text>                  send a raw IRC line to the server
#   /quit [msg]                  disconnect and exit
#   /help                        show this list again
#
# Anything typed without a leading "/" is sent as a PRIVMSG to the
# most recently joined channel.

set -u

command -v nc >/dev/null 2>&1 || {
    echo "raychd: 'nc' (netcat) not found. Install it first (e.g. 'pkg install netcat-openbsd' on Termux)."
    exit 1
}

SERVER="${1:-}"
PORT="${2:-}"
NICK="${3:-}"
INIT_CHANNEL="${4:-}"

if [ -z "$SERVER" ] || [ -z "$PORT" ] || [ -z "$NICK" ]; then
    echo "Usage: $0 <server> <port> <nickname> [#channel]"
    exit 1
fi

CURRENT_CHANNEL="$INIT_CHANNEL"
FIFO="$(mktemp -u "${TMPDIR:-/tmp}/raychd.XXXXXX")"
mkfifo "$FIFO"

# Keep the fifo open for both reading and writing so nc never sees EOF.
exec 3<>"$FIFO"

send_raw() {
    printf '%s\r\n' "$1" >&3
}

# --- start nc, reading its stdin from fd 3, piping its stdout to a reader --
nc "$SERVER" "$PORT" <&3 | while IFS= read -r line; do
    line="${line%$'\r'}"
    case "$line" in
        PING*)
            token="${line#PING }"
            printf 'PONG %s\r\n' "$token" >&3
            ;;
        *)
            echo "$line"
            ;;
    esac
done &
NC_PID=$!

cleanup() {
    send_raw "QUIT :raychd disconnecting" 2>/dev/null
    kill "$NC_PID" 2>/dev/null
    exec 3<&- 3>&-
    rm -f "$FIFO"
}
trap cleanup EXIT INT TERM

# --- registration ------------------------------------------------------------
send_raw "NICK $NICK"
send_raw "USER $NICK 0 * :$NICK (raychd)"

if [ -n "$INIT_CHANNEL" ]; then
    sleep 1
    send_raw "JOIN $INIT_CHANNEL"
fi

print_help() {
    cat <<'EOF'
Commands:
  /join #channel               join a channel
  /part #channel [msg]         leave a channel
  /msg <target> <text>         send a message to a channel or user
  /me <text>                   send an action to the current channel
  /nick <newnick>              change your nickname
  /topic #channel [text]       view or set a channel topic
  /kick #channel <nick> [msg]  kick a user from a channel
  /mode <target> <flags>       set user or channel modes
  /whois <nick>                look up info on a user
  /whowas <nick>               look up info on a disconnected user
  /invite <nick> #channel      invite a user to a channel
  /notice <target> <text>      send a notice
  /away [msg]                  mark yourself away (no arg clears it)
  /list                        list channels on the server
  /names #channel              list users in a channel
  /ctcp <target> <cmd>         send a CTCP request (e.g. VERSION)
  /raw <text>                  send a raw IRC line
  /quit [msg]                  disconnect and exit
  /help                        show this list
Anything without a leading "/" is sent to the current channel.
EOF
}

echo "Connected via nc. Type /help for commands."

# --- main input loop -----------------------------------------------------
while IFS= read -r input; do
    [ -z "$input" ] && continue

    case "$input" in
        /join\ *)
            chan="${input#/join }"
            send_raw "JOIN $chan"
            CURRENT_CHANNEL="$chan"
            ;;
        /part\ *)
            rest="${input#/part }"
            chan="${rest%% *}"
            msg="${rest#"$chan"}"
            msg="${msg# }"
            if [ -n "$msg" ] && [ "$msg" != "$chan" ]; then
                send_raw "PART $chan :$msg"
            else
                send_raw "PART $chan"
            fi
            ;;
        /msg\ *)
            rest="${input#/msg }"
            target="${rest%% *}"
            text="${rest#"$target" }"
            send_raw "PRIVMSG $target :$text"
            ;;
        /me\ *)
            text="${input#/me }"
            if [ -n "$CURRENT_CHANNEL" ]; then
                send_raw "PRIVMSG $CURRENT_CHANNEL :$(printf '\001ACTION %s\001' "$text")"
            else
                echo "No current channel. Use /join #channel first."
            fi
            ;;
        /nick\ *)
            newnick="${input#/nick }"
            send_raw "NICK $newnick"
            NICK="$newnick"
            ;;
        /topic\ *)
            rest="${input#/topic }"
            chan="${rest%% *}"
            text="${rest#"$chan"}"
            text="${text# }"
            if [ -n "$text" ] && [ "$text" != "$chan" ]; then
                send_raw "TOPIC $chan :$text"
            else
                send_raw "TOPIC $chan"
            fi
            ;;
        /kick\ *)
            rest="${input#/kick }"
            chan="${rest%% *}"
            rest2="${rest#"$chan" }"
            target="${rest2%% *}"
            msg="${rest2#"$target"}"
            msg="${msg# }"
            if [ -n "$msg" ] && [ "$msg" != "$target" ]; then
                send_raw "KICK $chan $target :$msg"
            else
                send_raw "KICK $chan $target"
            fi
            ;;
        /mode\ *)
            send_raw "MODE ${input#/mode }"
            ;;
        /whois\ *)
            send_raw "WHOIS ${input#/whois }"
            ;;
        /whowas\ *)
            send_raw "WHOWAS ${input#/whowas }"
            ;;
        /invite\ *)
            rest="${input#/invite }"
            target="${rest%% *}"
            chan="${rest#"$target" }"
            send_raw "INVITE $target $chan"
            ;;
        /notice\ *)
            rest="${input#/notice }"
            target="${rest%% *}"
            text="${rest#"$target" }"
            send_raw "NOTICE $target :$text"
            ;;
        /away)
            send_raw "AWAY"
            ;;
        /away\ *)
            send_raw "AWAY :${input#/away }"
            ;;
        /list)
            send_raw "LIST"
            ;;
        /names\ *)
            send_raw "NAMES ${input#/names }"
            ;;
        /ctcp\ *)
            rest="${input#/ctcp }"
            target="${rest%% *}"
            ctcp_cmd="${rest#"$target" }"
            send_raw "PRIVMSG $target :$(printf '\001%s\001' "$ctcp_cmd")"
            ;;
        /raw\ *)
            send_raw "${input#/raw }"
            ;;
        /quit)
            exit 0
            ;;
        /quit\ *)
            msg="${input#/quit }"
            send_raw "QUIT :$msg"
            exit 0
            ;;
        /help)
            print_help
            ;;
        /*)
            echo "Unknown command: $input (try /help)"
            ;;
        *)
            if [ -n "$CURRENT_CHANNEL" ]; then
                send_raw "PRIVMSG $CURRENT_CHANNEL :$input"
            else
                echo "No current channel. Use /join #channel or /msg <target> <text>."
            fi
            ;;
    esac
done
